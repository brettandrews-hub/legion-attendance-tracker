<script>
        // Clock functionality
        function updateClock() {
            const now = new Date();
            const timeString = now.toLocaleTimeString('en-GB', { hour12: false });
            document.getElementById('current-clock').textContent = timeString;
            return timeString;
        }
        setInterval(updateClock, 1000);
        updateClock();

        // Elements
        const startBtn = document.getElementById('start-btn');
        const overlay = document.getElementById('scan-status-overlay');
        const scanNewBtn = document.getElementById('scan-new-card-btn');
        const scannerBeam = document.getElementById('scanner-beam');
        const overlayId = document.getElementById('overlay-id');
        
        // Sidebar elements
        const studentPhoto = document.getElementById('student-photo');
        const studentName = document.getElementById('student-name');
        const studentId = document.getElementById('student-id');
        const studentMeta = document.getElementById('student-meta');
        const studentInstrument = document.getElementById('student-instrument');
        const studentSection = document.getElementById('student-section');
        const lastScanTime = document.getElementById('last-scan-time');
        const sessionLog = document.getElementById('session-log');
        const statPresent = document.getElementById('stat-present');
        const statAbsent = document.getElementById('stat-absent');

        let presentCount = 184;
        let absentCount = 66;

        function simulateScan() {
            // UI Feedback
            scanNewBtn.disabled = true;
            scanNewBtn.classList.add('opacity-50');
            scannerBeam.classList.add('laser-scan');
            
            setTimeout(() => {
                const currentTime = updateClock();
                
                // Update Student Data
                studentPhoto.src = 'https://lh3.googleusercontent.com/aida/ADBb0ugdOrGyh-9ewjXIZ6cOpYj06VmiDSOga5J-unhNhZIRk2oklLdqK_rdoMnNrIKMmZvgUobW_Bpf7AATdN5kqZnev8Fxrv74lmPEZK1QJGB6zAamkvuM-r0zJ5g2y6Mlk4SPHjURYaWXqjH_Yckh1gas8wJYU-bWE5K8oDQan1fAAADVcfslnPDInFGCktTj57cTbHlt1tWhlbyvAThgX8mnOwrbNjAIiVGK9pluwEbN6GREdPuVoNwVBW2z';
                studentName.textContent = 'TANYA JENKINS';
                studentId.textContent = 'ID: 00059950134';
                studentMeta.textContent = 'Junior • Member';
                studentInstrument.textContent = 'Flute';
                studentSection.textContent = 'Woodwinds';
                lastScanTime.textContent = currentTime;
                overlayId.textContent = 'ID: 00059950134';

                // Update Stats
                presentCount++;
                absentCount--;
                statPresent.innerHTML = `${presentCount} <span class="text-label-md font-normal text-on-surface-variant">/ 250</span>`;
                statAbsent.textContent = absentCount;

                // Show Success Overlay
                overlay.style.opacity = '1';
                
                // Add to Session Log
                const logEntry = document.createElement('div');
                logEntry.className = 'flex items-center justify-between bg-surface-container-lowest p-xs px-sm rounded border border-outline-variant/50 animate-in slide-in-from-right duration-300';
                logEntry.innerHTML = `
                    <span class="text-label-md">T. Jenkins</span>
                    <span class="text-label-md text-on-surface-variant">${currentTime.substring(0,5)}</span>
                    <span class="text-primary text-xs font-bold">OK</span>
                `;
                sessionLog.insertBefore(logEntry, sessionLog.firstChild);
                if(sessionLog.children.length > 3) {
                    sessionLog.lastElementChild.remove();
                }

                // Reset after simulation
                setTimeout(() => {
                    overlay.style.opacity = '0';
                    scannerBeam.classList.remove('laser-scan');
                    scanNewBtn.disabled = false;
                    scanNewBtn.classList.remove('opacity-50');
                }, 1500);

            }, 1500);
        }

        scanNewBtn.addEventListener('click', simulateScan);

        startBtn.addEventListener('click', () => {
            startBtn.classList.add('opacity-50', 'pointer-events-none');
            startBtn.textContent = 'SCANNING...';
            
            setTimeout(() => {
                overlay.style.opacity = '1';
                setTimeout(() => {
                    overlay.style.opacity = '0';
                    startBtn.classList.remove('opacity-50', 'pointer-events-none');
                    startBtn.innerHTML = '<span class="material-symbols-outlined text-[32px]">play_arrow</span> START SCAN';
                }, 1500);
            }, 2000);
        });

        function toggleTheme() {
            document.documentElement.classList.toggle('dark');
        }
    </script>
